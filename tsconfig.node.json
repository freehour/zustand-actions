/* Visit https://aka.ms/tsconfig to read more about this file */
{
  "include": [
    "vite.config.ts",
    "package.json",
  ],
  "compilerOptions": {
    "composite": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "ESNext"
    ],
    "resolveJsonModule": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
  }
}